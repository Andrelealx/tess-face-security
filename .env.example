PORT=3000
APP_NAME=TESS Face Security

# Banco (use apenas uma estrategia)
DATABASE_URL=mysql://root:root@127.0.0.1:3306/tess_security
# MYSQLHOST=127.0.0.1
# MYSQLPORT=3306
# MYSQLUSER=root
# MYSQLPASSWORD=root
# MYSQLDATABASE=tess_security

# OpenAI (TESS)
OPENAI_API_KEY=sk-xxxx
OPENAI_MODEL=gpt-4.1-mini

# Limiar de reconhecimento (distancia euclidiana; menor = mais rigido)
RECOGNITION_THRESHOLD=0.5
